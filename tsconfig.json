{
	"compilerOptions": {
		"target": "ES2022",                                  
		"module": "NodeNext",                                
		"moduleResolution": "NodeNext",                      
		"outDir": "./dist",                                   
		"rootDir": "./",                                     
		"esModuleInterop": true,                             
		"forceConsistentCasingInFileNames": true,            
		"strict": true,                                      
		"skipLibCheck": true,
		"types": ["jest", "node"],
		"isolatedModules": true,
	},
	"include": ["src/**/*", "bin/**/*", "tests/**/*"],
	"exclude": ["node_modules", "dist", "examples"]
}
